{
"01": "<div data-screen-label=\"01 Hook\" style=\"width:1080px;height:1920px;position:relative;background:radial-gradient(ellipse 72% 38% at 50% 44%, rgba(54,224,160,0.10), transparent 70%), #08090b;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;overflow:hidden;\">\n          <svg viewBox=\"0 0 1700 300\" style=\"width:960px;height:auto;filter:drop-shadow(0 0 7px rgba(54,224,160,0.85)) drop-shadow(0 0 22px rgba(54,224,160,0.45));\" preserveAspectRatio=\"xMidYMid meet\">\n            <polyline fill=\"none\" stroke=\"#36E0A0\" stroke-width=\"3.2\" stroke-linejoin=\"round\" stroke-linecap=\"round\" points=\"0,150.0 8,150.7 20,151.5 40,152.2 60,151.6 80,150.1 100,148.1 120,149.8 130,146.8 140,142.0 150,148.9 160,165.1 166,165.2 174,143.5 182,117.2 190,127.9 200,195.5 208,215.1 218,128.5 226,57.7 230,60.3 240,181.5 250,266.0 258,182.7 266,58.4 270,31.8 278,87.3 288,225.2 294,241.7 304,148.1 314,83.4 320,106.1 332,182.0 338,185.2 350,145.1 360,136.7 372,154.8 380,158.2 392,151.3 410,149.2 430,148.6 450,147.6 470,149.1 482,151.2 494,146.8 502,144.6 512,154.7 522,168.8 532,152.3 540,122.6 546,116.1 556,165.7 566,216.0 576,149.8 584,65.3 590,57.7 600,179.1 608,263.2 616,212.5 626,58.0 630,31.9 638,88.1 648,226.9 654,243.8 664,150.7 674,86.0 682,122.5 692,183.8 698,186.5 710,145.2 718,134.6 728,147.5 738,156.1 750,149.9 762,146.2 780,148.3 800,148.7 820,149.8 836,153.2 846,152.9 858,146.5 866,147.5 878,164.6 884,167.8 894,143.0 904,113.0 910,125.0 922,203.1 928,211.0 938,148.0 946,54.1 950,57.1 960,179.5 968,264.3 976,214.3 986,60.4 990,34.4 998,90.8 1010,242.9 1016,235.9 1026,130.0 1034,86.4 1044,136.9 1054,186.4 1058,184.6 1070,142.7 1078,132.2 1090,148.1 1100,154.1 1120,146.3 1140,150.2 1160,151.3 1180,151.7 1200,153.8 1212,148.8 1220,144.1 1232,152.5 1244,165.2 1252,148.2 1262,113.5 1266,112.0 1278,177.5 1288,211.5 1298,125.9 1306,56.1 1310,59.3 1320,182.1 1328,266.9 1338,185.8 1348,44.4 1352,36.8 1362,152.0 1372,247.7 1378,218.3 1388,109.3 1394,84.0 1406,148.8 1416,184.7 1424,163.1 1434,132.8 1444,138.2 1456,154.7 1462,155.0 1474,149.4 1486,149.8 1500,152.5 1520,152.1 1540,151.0 1560,149.3 1580,148.1 1600,147.9 1620,148.9 1640,150.5 1660,151.9 1680,152.2 1700,151.2\"></polyline>\n          </svg>\n          <div style=\"margin-top:96px;font-size:42px;font-weight:600;letter-spacing:-0.01em;color:#fff;\">Every step sends a signal.</div>\n        </div>",
"02": "<div data-screen-label=\"02 Problem\" style=\"width:1080px;height:1920px;position:relative;background:radial-gradient(ellipse 60% 40% at 18% 30%, rgba(229,72,77,0.07), transparent 70%), #08090b;display:flex;flex-direction:column;align-items:flex-start;justify-content:center;padding:0 120px;color:#fff;overflow:hidden;\">\n          <div style=\"font-size:24px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#36E0A0;text-shadow:0 0 20px rgba(54,224,160,0.5);\">The real problem</div>\n          <div style=\"margin-top:40px;font-size:96px;font-weight:800;line-height:1.04;letter-spacing:-0.025em;max-width:860px;\">Detection is easy.<br>Staying <span style=\"color:#E5484D;text-shadow:0 0 30px rgba(229,72,77,0.45);\">invisible</span> isn’t.</div>\n          <div style=\"margin-top:48px;font-size:33px;line-height:1.55;color:rgba(255,255,255,0.6);max-width:760px;\">The white cane works — but it announces you.</div>\n        </div>",
"03": "<div data-screen-label=\"03 Hero\" style=\"width:1080px;height:1920px;position:relative;background:radial-gradient(ellipse 80% 50% at 50% 62%, rgba(54,224,160,0.09), transparent 70%), #08090b;display:flex;flex-direction:column;align-items:center;padding:150px 60px 0;color:#fff;overflow:hidden;\">\n          <div style=\"font-size:24px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#36E0A0;text-shadow:0 0 20px rgba(54,224,160,0.5);\">Wearable navigation device</div>\n          <div style=\"margin-top:24px;font-size:212px;font-weight:800;letter-spacing:-0.045em;line-height:0.95;\">BatNAV</div>\n          <div style=\"margin-top:26px;width:240px;height:8px;border-radius:4px;background:#36E0A0;box-shadow:0 0 28px rgba(54,224,160,0.8);\"></div>\n          <div style=\"margin-top:44px;font-size:36px;line-height:1.4;color:rgba(255,255,255,0.62);text-align:center;\">The cane, reimagined for your shoe.</div>\n\n          <!-- device hero with floating pills -->\n          <div style=\"margin-top:96px;position:relative;width:780px;height:760px;\">\n            <svg viewBox=\"0 0 780 760\" style=\"position:absolute;inset:0;width:100%;height:100%;pointer-events:none;\">\n              <line x1=\"205\" y1=\"118\" x2=\"320\" y2=\"248\" stroke=\"#36E0A0\" stroke-width=\"1.6\" opacity=\"0.75\"></line>\n              <circle cx=\"320\" cy=\"248\" r=\"5\" fill=\"#36E0A0\"></circle>\n              <line x1=\"640\" y1=\"350\" x2=\"556\" y2=\"380\" stroke=\"#F5A623\" stroke-width=\"1.6\" opacity=\"0.75\"></line>\n              <circle cx=\"556\" cy=\"380\" r=\"5\" fill=\"#F5A623\"></circle>\n              <line x1=\"232\" y1=\"676\" x2=\"330\" y2=\"540\" stroke=\"#E5484D\" stroke-width=\"1.6\" opacity=\"0.75\"></line>\n              <circle cx=\"330\" cy=\"540\" r=\"5\" fill=\"#E5484D\"></circle>\n            </svg>\n            <!-- device image -->\n            <div style=\"position:absolute;left:170px;top:170px;width:440px;height:440px;border-radius:30px;overflow:hidden;border:1px solid rgba(255,255,255,0.12);box-shadow:0 0 90px rgba(54,224,160,0.18), inset 0 0 0 1px rgba(255,255,255,0.04);\">\n              <img src=\"__DEVICE_IMG__\" style=\"width:100%;height:100%;object-fit:cover;object-position:center 38%;filter:contrast(1.06) brightness(0.92) saturate(0.9);\" alt=\"BatNAV device\">\n              <div style=\"position:absolute;inset:0;background:radial-gradient(circle at 50% 40%, transparent 38%, rgba(8,9,11,0.5) 100%), linear-gradient(180deg, rgba(8,9,11,0.35) 0%, transparent 28%, transparent 58%, rgba(8,9,11,0.92) 100%);\"></div>\n            </div>\n            <!-- pills -->\n            <div style=\"position:absolute;left:60px;top:84px;display:inline-flex;align-items:center;gap:10px;padding:13px 22px;border-radius:999px;background:rgba(54,224,160,0.12);border:1px solid rgba(54,224,160,0.4);color:#36E0A0;font-size:24px;font-weight:600;white-space:nowrap;\">HC-SR04</div>\n            <div style=\"position:absolute;left:618px;top:322px;display:inline-flex;align-items:center;gap:10px;padding:13px 22px;border-radius:999px;background:rgba(245,166,35,0.12);border:1px solid rgba(245,166,35,0.4);color:#F5A623;font-size:24px;font-weight:600;white-space:nowrap;\">MPU6050</div>\n            <div style=\"position:absolute;left:34px;top:648px;display:inline-flex;align-items:center;gap:10px;padding:13px 22px;border-radius:999px;background:rgba(229,72,77,0.12);border:1px solid rgba(229,72,77,0.4);color:#E5484D;font-size:24px;font-weight:600;white-space:nowrap;\">vibration motors</div>\n          </div>\n        </div>",
"04": "<div data-screen-label=\"04 How it sees\" style=\"width:1080px;height:1920px;position:relative;background:#08090b;display:flex;flex-direction:column;padding:120px 80px;color:#fff;overflow:hidden;\">\n          <div style=\"font-size:24px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#36E0A0;text-shadow:0 0 20px rgba(54,224,160,0.5);\">See it, feel it</div>\n          <div style=\"margin-top:32px;font-size:88px;font-weight:800;line-height:1.04;letter-spacing:-0.025em;max-width:900px;\">What your foot actually feels.</div>\n          <div style=\"margin-top:40px;font-size:31px;line-height:1.55;color:rgba(255,255,255,0.6);max-width:820px;\">Ultrasonic distance, mapped straight to vibration — no screen, no sound, just touch.</div>\n\n          <div style=\"margin-top:auto;display:flex;gap:36px;background:#0e1014;border:1px solid rgba(255,255,255,0.08);border-radius:28px;padding:44px;height:760px;\">\n            <div style=\"position:relative;width:380px;flex:none;border-radius:20px;overflow:hidden;border:1px solid rgba(255,255,255,0.08);\">\n              <img src=\"__DEVICE_IMG__\" style=\"width:100%;height:100%;object-fit:cover;object-position:center 40%;filter:contrast(1.06) brightness(0.9) saturate(0.9);\" alt=\"BatNAV device\">\n              <div style=\"position:absolute;inset:0;background:linear-gradient(180deg, rgba(14,16,20,0.3) 0%, transparent 30%, transparent 62%, rgba(14,16,20,0.85) 100%);\"></div>\n            </div>\n            <div style=\"flex:1;display:flex;flex-direction:column;justify-content:center;gap:22px;\">\n              <div style=\"display:flex;align-items:center;gap:18px;padding:24px 26px;border-radius:16px;background:rgba(54,224,160,0.07);border:1px solid rgba(54,224,160,0.22);\">\n                <span style=\"width:14px;height:14px;border-radius:50%;background:#36E0A0;box-shadow:0 0 16px rgba(54,224,160,0.8);flex:none;\"></span>\n                <div><div style=\"font-size:30px;font-weight:700;\">Ultrasonic sensor</div><div style=\"font-size:21px;color:rgba(255,255,255,0.5);margin-top:4px;\">HC-SR04 · scans the path</div></div>\n              </div>\n              <div style=\"display:flex;align-items:center;gap:18px;padding:24px 26px;border-radius:16px;background:rgba(245,166,35,0.07);border:1px solid rgba(245,166,35,0.22);\">\n                <span style=\"width:14px;height:14px;border-radius:50%;background:#F5A623;box-shadow:0 0 16px rgba(245,166,35,0.7);flex:none;\"></span>\n                <div><div style=\"font-size:30px;font-weight:700;\">Gyroscope</div><div style=\"font-size:21px;color:rgba(255,255,255,0.5);margin-top:4px;\">MPU6050 · reads foot angle</div></div>\n              </div>\n              <div style=\"display:flex;align-items:center;gap:18px;padding:24px 26px;border-radius:16px;background:rgba(229,72,77,0.07);border:1px solid rgba(229,72,77,0.22);\">\n                <span style=\"width:14px;height:14px;border-radius:50%;background:#E5484D;box-shadow:0 0 16px rgba(229,72,77,0.7);flex:none;\"></span>\n                <div><div style=\"font-size:30px;font-weight:700;\">Vibration motors</div><div style=\"font-size:21px;color:rgba(255,255,255,0.5);margin-top:4px;\">2× KG-160 · feel the distance</div></div>\n              </div>\n              <div style=\"display:flex;align-items:center;gap:18px;padding:24px 26px;border-radius:16px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);\">\n                <span style=\"width:14px;height:14px;border-radius:50%;background:rgba(255,255,255,0.7);flex:none;\"></span>\n                <div><div style=\"font-size:30px;font-weight:700;\">Custom PCB</div><div style=\"font-size:21px;color:rgba(255,255,255,0.5);margin-top:4px;\">Zero-PCB · Arduino Nano · 9V</div></div>\n              </div>\n            </div>\n          </div>\n        </div>",
"05": "<div data-screen-label=\"05 Proximity\" style=\"width:1080px;height:1920px;position:relative;background:radial-gradient(ellipse 70% 45% at 75% 75%, rgba(229,72,77,0.08), transparent 70%), #08090b;display:flex;flex-direction:column;padding:120px 80px;color:#fff;overflow:hidden;\">\n          <div style=\"font-size:24px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#F5A623;text-shadow:0 0 20px rgba(245,166,35,0.5);\">Proximity feedback</div>\n          <div style=\"margin-top:32px;font-size:88px;font-weight:800;line-height:1.04;letter-spacing:-0.025em;max-width:900px;\">Watch the distance <span style=\"color:#F5A623;text-shadow:0 0 30px rgba(245,166,35,0.5);\">light up</span>.</div>\n          <div style=\"margin-top:40px;font-size:31px;line-height:1.55;color:rgba(255,255,255,0.6);max-width:820px;\">Far is calm. Close glows amber. Danger pulses red.</div>\n          <div style=\"margin-top:36px;display:flex;gap:40px;\">\n            <div style=\"display:flex;align-items:center;gap:12px;font-size:24px;color:rgba(255,255,255,0.7);\"><span style=\"width:16px;height:16px;border-radius:50%;background:#36E0A0;box-shadow:0 0 14px rgba(54,224,160,0.8);\"></span>Far</div>\n            <div style=\"display:flex;align-items:center;gap:12px;font-size:24px;color:rgba(255,255,255,0.7);\"><span style=\"width:16px;height:16px;border-radius:50%;background:#F5A623;box-shadow:0 0 14px rgba(245,166,35,0.8);\"></span>Close</div>\n            <div style=\"display:flex;align-items:center;gap:12px;font-size:24px;color:rgba(255,255,255,0.7);\"><span style=\"width:16px;height:16px;border-radius:50%;background:#E5484D;box-shadow:0 0 14px rgba(229,72,77,0.8);\"></span>Danger</div>\n          </div>\n\n          <div style=\"margin-top:auto;display:flex;flex-direction:column;gap:24px;background:#0e1014;border:1px solid rgba(255,255,255,0.08);border-radius:28px;padding:44px;height:700px;justify-content:center;\">\n            <!-- FAR -->\n            <div style=\"display:flex;align-items:center;gap:32px;padding:34px 40px;border-radius:20px;background:rgba(54,224,160,0.06);border:1px solid rgba(54,224,160,0.28);box-shadow:0 0 30px rgba(54,224,160,0.08);\">\n              <div style=\"flex:1;\"><div style=\"font-size:34px;font-weight:800;color:#36E0A0;letter-spacing:0.04em;\">FAR</div><div style=\"font-size:22px;color:rgba(255,255,255,0.5);margin-top:4px;\">over 120 cm · calm</div></div>\n              <div style=\"display:flex;gap:10px;\">\n                <span style=\"width:22px;height:54px;border-radius:6px;background:#36E0A0;box-shadow:0 0 14px rgba(54,224,160,0.7);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:rgba(54,224,160,0.16);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:rgba(54,224,160,0.16);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:rgba(54,224,160,0.16);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:rgba(54,224,160,0.16);\"></span>\n              </div>\n            </div>\n            <!-- CLOSE -->\n            <div style=\"display:flex;align-items:center;gap:32px;padding:34px 40px;border-radius:20px;background:rgba(245,166,35,0.07);border:1px solid rgba(245,166,35,0.32);box-shadow:0 0 36px rgba(245,166,35,0.1);\">\n              <div style=\"flex:1;\"><div style=\"font-size:34px;font-weight:800;color:#F5A623;letter-spacing:0.04em;\">CLOSE</div><div style=\"font-size:22px;color:rgba(255,255,255,0.5);margin-top:4px;\">40–120 cm · caution</div></div>\n              <div style=\"display:flex;gap:10px;\">\n                <span style=\"width:22px;height:54px;border-radius:6px;background:#F5A623;box-shadow:0 0 14px rgba(245,166,35,0.7);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:#F5A623;box-shadow:0 0 14px rgba(245,166,35,0.7);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:#F5A623;box-shadow:0 0 14px rgba(245,166,35,0.7);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:rgba(245,166,35,0.18);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:rgba(245,166,35,0.18);\"></span>\n              </div>\n            </div>\n            <!-- DANGER -->\n            <div style=\"display:flex;align-items:center;gap:32px;padding:34px 40px;border-radius:20px;background:rgba(229,72,77,0.09);border:1px solid rgba(229,72,77,0.42);box-shadow:0 0 48px rgba(229,72,77,0.16);\">\n              <div style=\"flex:1;\"><div style=\"font-size:34px;font-weight:800;color:#E5484D;letter-spacing:0.04em;\">DANGER</div><div style=\"font-size:22px;color:rgba(255,255,255,0.5);margin-top:4px;\">under 40 cm · pulses hard</div></div>\n              <div style=\"display:flex;gap:10px;\">\n                <span style=\"width:22px;height:54px;border-radius:6px;background:#E5484D;box-shadow:0 0 16px rgba(229,72,77,0.9);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:#E5484D;box-shadow:0 0 16px rgba(229,72,77,0.9);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:#E5484D;box-shadow:0 0 16px rgba(229,72,77,0.9);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:#E5484D;box-shadow:0 0 16px rgba(229,72,77,0.9);\"></span>\n                <span style=\"width:22px;height:54px;border-radius:6px;background:#E5484D;box-shadow:0 0 16px rgba(229,72,77,0.9);\"></span>\n              </div>\n            </div>\n          </div>\n        </div>",
"06": "<div data-screen-label=\"06 The fix\" style=\"width:1080px;height:1920px;position:relative;background:#08090b;display:flex;flex-direction:column;padding:120px 80px;color:#fff;overflow:hidden;\">\n          <div style=\"font-size:24px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#36E0A0;text-shadow:0 0 20px rgba(54,224,160,0.5);\">The engineering</div>\n          <div style=\"margin-top:32px;font-size:88px;font-weight:800;line-height:1.04;letter-spacing:-0.025em;max-width:900px;\">The fix that made it usable.</div>\n          <div style=\"margin-top:40px;font-size:31px;line-height:1.55;color:rgba(255,255,255,0.6);max-width:840px;\">Walking bends the foot — and the sensor saw the ground. So the gyro cuts the motors the instant your foot tips.</div>\n\n          <div style=\"margin-top:auto;position:relative;background:#0e1014;border:1px solid rgba(255,255,255,0.08);border-radius:28px;padding:0;height:760px;overflow:hidden;\">\n            <svg viewBox=\"0 0 892 760\" style=\"position:absolute;inset:0;width:100%;height:100%;\">\n              <!-- ground -->\n              <line x1=\"70\" y1=\"600\" x2=\"822\" y2=\"600\" stroke=\"rgba(255,255,255,0.22)\" stroke-width=\"2\" stroke-dasharray=\"2 12\" stroke-linecap=\"round\"></line>\n              <!-- threshold reference (level foot) -->\n              <line x1=\"150\" y1=\"600\" x2=\"560\" y2=\"600\" stroke=\"rgba(54,224,160,0.5)\" stroke-width=\"3\" stroke-dasharray=\"10 10\"></line>\n              <!-- angle arc -->\n              <path d=\"M 330 600 A 180 180 0 0 0 215 432\" fill=\"none\" stroke=\"#F5A623\" stroke-width=\"2.5\" stroke-dasharray=\"6 8\"></path>\n            </svg>\n            <div style=\"position:absolute;left:48px;top:44px;font-family:'JetBrains Mono',monospace;font-size:21px;letter-spacing:0.16em;color:rgba(255,255,255,0.45);\">FOOT-TIP CUTOFF</div>\n\n            <!-- tilted shoe -->\n            <div style=\"position:absolute;left:150px;top:360px;width:420px;height:120px;transform:rotate(-26deg);transform-origin:0% 100%;\">\n              <div style=\"position:relative;width:100%;height:100%;\">\n                <!-- shoe body -->\n                <div style=\"position:absolute;left:0;bottom:24px;width:100%;height:78px;border-radius:48px 70px 26px 18px;background:linear-gradient(180deg,#2a2d34,#1a1c22);border:1px solid rgba(255,255,255,0.14);\"></div>\n                <!-- sole -->\n                <div style=\"position:absolute;left:0;bottom:6px;width:100%;height:26px;border-radius:8px 30px 14px 8px;background:#0c0d10;border:1px solid rgba(255,255,255,0.1);\"></div>\n                <!-- MPU chip -->\n                <div style=\"position:absolute;left:150px;bottom:42px;width:84px;height:48px;border-radius:8px;background:rgba(54,224,160,0.14);border:1px solid rgba(54,224,160,0.5);display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;font-size:17px;font-weight:600;color:#36E0A0;\">MPU</div>\n                <!-- sensor arrow pointing down toward ground -->\n                <div style=\"position:absolute;right:-6px;bottom:30px;width:16px;height:16px;border-radius:50%;background:#E5484D;box-shadow:0 0 14px rgba(229,72,77,0.8);\"></div>\n              </div>\n            </div>\n\n            <!-- angle label -->\n            <div style=\"position:absolute;left:248px;top:520px;font-size:30px;font-weight:800;color:#F5A623;text-shadow:0 0 20px rgba(245,166,35,0.4);\">26° tip</div>\n            <div style=\"position:absolute;left:170px;top:618px;font-family:'JetBrains Mono',monospace;font-size:18px;color:#36E0A0;\">threshold = level</div>\n\n            <!-- MPU6050 callout -->\n            <div style=\"position:absolute;left:380px;top:300px;display:inline-flex;align-items:center;gap:10px;padding:13px 22px;border-radius:999px;background:rgba(54,224,160,0.12);border:1px solid rgba(54,224,160,0.4);color:#36E0A0;font-size:23px;font-weight:600;\">MPU6050 gyro</div>\n\n            <!-- MOTORS CUT indicator -->\n            <div style=\"position:absolute;right:48px;top:120px;display:inline-flex;flex-direction:column;gap:14px;padding:34px 38px;border-radius:20px;background:rgba(245,166,35,0.1);border:1px solid rgba(245,166,35,0.5);box-shadow:0 0 50px rgba(245,166,35,0.2);\">\n              <div style=\"display:flex;align-items:center;gap:14px;\">\n                <span style=\"width:18px;height:18px;border-radius:50%;background:#F5A623;box-shadow:0 0 18px rgba(245,166,35,0.9);\"></span>\n                <span style=\"font-size:32px;font-weight:800;color:#F5A623;letter-spacing:0.04em;\">MOTORS CUT</span>\n              </div>\n              <div style=\"font-size:22px;color:rgba(255,255,255,0.6);max-width:320px;line-height:1.45;\">Tilt past threshold → ground reading ignored. No false buzz mid-stride.</div>\n            </div>\n          </div>\n        </div>",
"07": "<div data-screen-label=\"07 Open hardware\" style=\"width:1080px;height:1920px;position:relative;background:#08090b;display:flex;flex-direction:column;padding:120px 80px;color:#fff;overflow:hidden;\">\n          <div style=\"font-size:24px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#36E0A0;text-shadow:0 0 20px rgba(54,224,160,0.5);\">Open hardware</div>\n          <div style=\"margin-top:32px;font-size:88px;font-weight:800;line-height:1.04;letter-spacing:-0.025em;max-width:900px;\">Real parts. Fully documented.</div>\n          <div style=\"margin-top:40px;font-size:31px;line-height:1.55;color:rgba(255,255,255,0.6);max-width:820px;\">Every component, every file — open and reproducible.</div>\n\n          <div style=\"margin-top:auto;background:#0e1014;border:1px solid rgba(255,255,255,0.08);border-radius:28px;padding:44px;height:820px;display:flex;flex-direction:column;\">\n            <div style=\"display:flex;justify-content:space-between;align-items:baseline;\">\n              <div style=\"font-size:34px;font-weight:700;\">Bill of materials</div>\n              <div style=\"font-family:'JetBrains Mono',monospace;font-size:21px;color:rgba(255,255,255,0.45);\">5 core parts</div>\n            </div>\n            <div style=\"margin-top:30px;display:flex;flex-direction:column;gap:18px;flex:1;\">\n              <div style=\"display:flex;align-items:center;gap:22px;padding:26px 28px;border-radius:16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);\">\n                <span style=\"width:46px;height:46px;border-radius:11px;background:rgba(54,224,160,0.14);flex:none;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;color:#36E0A0;font-size:22px;font-weight:600;\">01</span>\n                <div style=\"flex:1;font-size:30px;font-weight:700;\">Arduino Nano</div>\n                <span style=\"padding:9px 18px;border-radius:999px;background:rgba(54,224,160,0.12);color:#36E0A0;font-size:19px;font-weight:600;letter-spacing:0.08em;\">MCU</span>\n              </div>\n              <div style=\"display:flex;align-items:center;gap:22px;padding:26px 28px;border-radius:16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);\">\n                <span style=\"width:46px;height:46px;border-radius:11px;background:rgba(54,224,160,0.14);flex:none;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;color:#36E0A0;font-size:22px;font-weight:600;\">02</span>\n                <div style=\"flex:1;font-size:30px;font-weight:700;\">HC-SR04</div>\n                <span style=\"padding:9px 18px;border-radius:999px;background:rgba(54,224,160,0.12);color:#36E0A0;font-size:19px;font-weight:600;letter-spacing:0.08em;\">SENSOR</span>\n              </div>\n              <div style=\"display:flex;align-items:center;gap:22px;padding:26px 28px;border-radius:16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);\">\n                <span style=\"width:46px;height:46px;border-radius:11px;background:rgba(245,166,35,0.14);flex:none;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;color:#F5A623;font-size:22px;font-weight:600;\">03</span>\n                <div style=\"flex:1;font-size:30px;font-weight:700;\">MPU6050</div>\n                <span style=\"padding:9px 18px;border-radius:999px;background:rgba(245,166,35,0.12);color:#F5A623;font-size:19px;font-weight:600;letter-spacing:0.08em;\">GYRO</span>\n              </div>\n              <div style=\"display:flex;align-items:center;gap:22px;padding:26px 28px;border-radius:16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);\">\n                <span style=\"width:46px;height:46px;border-radius:11px;background:rgba(229,72,77,0.14);flex:none;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;color:#E5484D;font-size:22px;font-weight:600;\">04</span>\n                <div style=\"flex:1;font-size:30px;font-weight:700;\">KG-160 <span style=\"color:rgba(255,255,255,0.45);font-weight:500;\">×2</span></div>\n                <span style=\"padding:9px 18px;border-radius:999px;background:rgba(229,72,77,0.12);color:#E5484D;font-size:19px;font-weight:600;letter-spacing:0.08em;\">HAPTICS</span>\n              </div>\n              <div style=\"display:flex;align-items:center;gap:22px;padding:26px 28px;border-radius:16px;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);\">\n                <span style=\"width:46px;height:46px;border-radius:11px;background:rgba(255,255,255,0.08);flex:none;display:flex;align-items:center;justify-content:center;font-family:'JetBrains Mono',monospace;color:rgba(255,255,255,0.7);font-size:22px;font-weight:600;\">05</span>\n                <div style=\"flex:1;font-size:30px;font-weight:700;\">Custom PCB</div>\n                <span style=\"padding:9px 18px;border-radius:999px;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.7);font-size:19px;font-weight:600;letter-spacing:0.08em;\">ZERO-PCB</span>\n              </div>\n            </div>\n            <div style=\"margin-top:24px;display:flex;align-items:center;gap:16px;padding:26px 30px;border-radius:16px;background:rgba(54,224,160,0.1);border:1px solid rgba(54,224,160,0.4);box-shadow:0 0 36px rgba(54,224,160,0.12);\">\n              <span style=\"width:34px;height:34px;border-radius:50%;background:#36E0A0;box-shadow:0 0 18px rgba(54,224,160,0.8);flex:none;display:flex;align-items:center;justify-content:center;color:#06231a;font-weight:800;font-size:22px;\">✓</span>\n              <div style=\"font-size:27px;font-weight:700;color:#36E0A0;\">OSHWA certified</div>\n              <div style=\"margin-left:auto;font-family:'JetBrains Mono',monospace;font-size:23px;color:#36E0A0;letter-spacing:0.08em;\">IN000035</div>\n            </div>\n          </div>\n        </div>",
"08": "<div data-screen-label=\"08 Outro\" style=\"width:1080px;height:1920px;position:relative;background:radial-gradient(ellipse 80% 50% at 50% 64%, rgba(54,224,160,0.12), transparent 72%), #08090b;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:0 80px;color:#fff;overflow:hidden;\">\n          <div style=\"font-size:24px;font-weight:600;letter-spacing:0.22em;text-transform:uppercase;color:#36E0A0;text-shadow:0 0 20px rgba(54,224,160,0.5);\">See the path · walk free</div>\n          <div style=\"margin-top:44px;font-size:118px;font-weight:800;line-height:1.0;letter-spacing:-0.035em;text-align:center;\">Navigation<br>you wear.</div>\n          <div style=\"margin-top:84px;display:inline-flex;align-items:center;gap:16px;padding:34px 70px;border-radius:999px;background:#36E0A0;color:#06231a;font-size:38px;font-weight:700;box-shadow:0 0 70px rgba(54,224,160,0.55);\">View the project →</div>\n          <div style=\"margin-top:72px;font-size:40px;font-weight:700;color:#36E0A0;text-shadow:0 0 34px rgba(54,224,160,0.55);text-align:center;line-height:1.25;\">makersasylum.com/project/<br>project-bat-nav</div>\n          <div style=\"margin-top:40px;font-size:22px;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:rgba(255,255,255,0.4);\">Open-source wearable · UN SDG 10</div>\n        </div>"
